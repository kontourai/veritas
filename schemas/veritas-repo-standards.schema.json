{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-repo-standards.schema.json",
  "title": "Veritas Repo Standards",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "rules"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "classification", "enforcementLevel", "message", "match"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "description": "The evidence-check primitive that produces readiness evidence for this requirement. forbidden-pattern / required-pattern / header-required / vocabulary-consistency are content evidence checks (they emit findings as readiness evidence), NOT a generic-lint surface.",
            "type": "string",
            "enum": [
              "required-artifacts",
              "governance-block",
              "diff-required",
              "work-area-boundary",
              "forbidden-pattern",
              "required-pattern",
              "header-required",
              "vocabulary-consistency",
              "primitive-first-governance"
            ]
          },
          "classification": {
            "type": "string",
            "enum": [
              "hard-invariant",
              "promotable-policy",
              "advisory-pattern",
              "brittle-implementation-check"
            ]
          },
          "enforcementLevel": {
            "description": "How strongly Veritas applies the requirement (the canonical Enforcement Level, CONTEXT.md). Observe: record evidence only. Guide: give just-in-time agent-facing correction without blocking merge readiness. Require: must be satisfied or accepted by exception.",
            "type": "string",
            "enum": ["Observe", "Guide", "Require"]
          },
          "enforcement": {
            "description": "Derived runtime hard-gate flag (not authored): 'deny' makes the PreToolUse hook block on a failing hard-invariant; 'advisory' records only. Defaulted from classification in src/rules/result.mjs.",
            "type": "string",
            "enum": ["deny", "advisory"]
          },
          "message": { "type": "string" },
          "owner": { "type": ["string", "null"] },
          "rollback_switch": { "type": ["string", "null"] },
          "explain": { "$ref": "#/$defs/explain" },
          "match": {
            "oneOf": [
              { "$ref": "#/$defs/requiredArtifactsMatch" },
              { "$ref": "#/$defs/governanceBlockMatch" },
              { "$ref": "#/$defs/diffRequiredMatch" },
              { "$ref": "#/$defs/filesPatternMatch" },
              { "$ref": "#/$defs/vocabularyConsistencyMatch" },
              { "$ref": "#/$defs/primitiveFirstGovernanceMatch" },
              { "$ref": "#/$defs/emptyMatch" }
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "kind": { "const": "required-artifacts" } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "match": { "$ref": "#/$defs/requiredArtifactsMatch" }
              }
            }
          },
          {
            "if": {
              "properties": { "kind": { "const": "governance-block" } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "match": { "$ref": "#/$defs/governanceBlockMatch" }
              }
            }
          },
          {
            "if": {
              "properties": { "kind": { "const": "diff-required" } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "match": { "$ref": "#/$defs/diffRequiredMatch" }
              }
            }
          }
        ,
          {
            "if": {
              "properties": { "kind": { "const": "work-area-boundary" } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "match": { "$ref": "#/$defs/emptyMatch" }
              }
            }
          },
          {
            "if": {
              "properties": { "kind": { "enum": ["forbidden-pattern", "required-pattern", "header-required"] } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "match": { "$ref": "#/$defs/filesPatternMatch" }
              }
            }
          },
          {
            "if": {
              "properties": { "kind": { "const": "vocabulary-consistency" } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "match": { "$ref": "#/$defs/vocabularyConsistencyMatch" }
              }
            }
          },
          {
            "if": {
              "properties": { "kind": { "const": "primitive-first-governance" } },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "match": { "$ref": "#/$defs/primitiveFirstGovernanceMatch" }
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "explain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string" },
        "mustDo": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustNotDo": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exampleGood": { "type": "string" },
        "exampleBad": { "type": "string" },
        "contextLinks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "requiredArtifactsMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "governanceBlockMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["governance-block"],
      "properties": {
        "governance-block": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "diffRequiredMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["if-changed", "then-require"],
      "properties": {
        "if-changed": { "type": "string" },
        "then-require": { "type": "string" }
      }
    },
    "filesPatternMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "pattern"],
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pattern": { "type": "string" }
      }
    },
    "vocabularyConsistencyMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "terms"],
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "terms": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["term", "prefer"],
            "properties": {
              "term": { "type": "string" },
              "pattern": { "type": "string" },
              "regex": { "type": "string" },
              "flags": { "type": "string" },
              "prefer": { "type": "string" },
              "allowContexts": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "primitiveFirstGovernanceMatch": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["candidates"] },
        { "required": ["packageScripts"] }
      ],
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["files", "pattern", "representedBy"],
            "properties": {
              "files": {
                "type": "array",
                "items": { "type": "string" }
              },
              "pattern": { "type": "string" },
              "representedBy": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "id"],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": ["repo-standards-rule", "evidence-check"]
                    },
                    "id": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "packageScripts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["namePatterns", "commandPatterns"],
          "properties": {
            "file": { "type": "string", "default": "package.json" },
            "namePatterns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "commandPatterns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "representedBy": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "id"],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["repo-standards-rule", "evidence-check"]
                  },
                  "id": { "type": "string" }
                }
              }
            },
            "helperExemptions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "rationale"],
                "properties": {
                  "name": { "type": "string" },
                  "rationale": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "emptyMatch": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 0
    }
  }
}
