{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-marker-transcript.schema.json",
  "title": "Veritas Marker Benchmark Transcript",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "benchmark_id", "run_id", "condition_id", "turns"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "benchmark_id": { "type": "string" },
    "run_id": { "type": "string" },
    "condition_id": {
      "type": "string",
      "enum": ["without-veritas", "with-veritas"]
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant", "tool"]
          },
          "content": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
