{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-adapter.schema.json",
  "title": "Veritas Adapter",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "kind", "graph", "evidence"],
  "properties": {
    "name": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["repo-adapter"]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultFalsePositiveReview",
        "defaultPromotionCandidate",
        "defaultOverrideOrBypass"
      ],
      "properties": {
        "defaultFalsePositiveReview": {
          "type": "string",
          "enum": ["unknown", "accepted", "rejected"]
        },
        "defaultPromotionCandidate": { "type": "boolean" },
        "defaultOverrideOrBypass": { "type": "boolean" }
      }
    },
    "graph": { "$ref": "./veritas-graph.schema.json" },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aiInstructionFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "tool": { "type": "string" },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactDir", "reportTransport"],
      "properties": {
        "artifactDir": { "type": "string" },
        "proofLanes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "command", "method"],
            "properties": {
              "id": { "type": "string" },
              "command": { "type": "string" },
              "method": {
                "enum": ["observation", "extraction", "validation", "corroboration", "attestation", "auditability", "anchoring", "monitoring"]
              },
              "surfaceClaimIds": {
                "type": "array",
                "items": { "type": "string" }
              },
              "summary": { "type": "string" }
            }
          },
          "minItems": 1
        },
        "requiredProofLaneIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaultProofLaneIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surfaceProofRoutes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nodeIds", "proofLaneIds"],
            "properties": {
              "nodeIds": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "proofLaneIds": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            }
          }
        },
        "proofFamilyManifests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uncoveredPathPolicy": {
          "type": "string",
          "enum": ["ignore", "warn", "fail"]
        },
        "reportTransport": { "type": "string" }
      },
      "anyOf": [
        { "required": ["proofLanes"] }
      ]
    }
  }
}
