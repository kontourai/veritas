{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-adapter.schema.json",
  "title": "Veritas Adapter",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "kind", "graph", "evidence"],
  "properties": {
    "name": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["repo-adapter"]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultFalsePositiveReview",
        "defaultPromotionCandidate",
        "defaultOverrideOrBypass"
      ],
      "properties": {
        "defaultFalsePositiveReview": {
          "type": "string",
          "enum": ["unknown", "accepted", "rejected"]
        },
        "defaultPromotionCandidate": { "type": "boolean" },
        "defaultOverrideOrBypass": { "type": "boolean" }
      }
    },
    "graph": {
      "allOf": [
        { "$ref": "./veritas-graph.schema.json" },
        {
          "type": "object",
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "owners": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "boundary": {
                    "type": "string",
                    "enum": ["strict", "advisory"]
                  },
                  "crossSurfaceAllow": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aiInstructionFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "tool": { "type": "string" },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactDir", "reportTransport"],
      "properties": {
        "artifactDir": { "type": "string" },
        "proofs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "command", "method"],
            "properties": {
              "id": { "type": "string" },
              "command": { "type": "string" },
              "method": {
                "enum": ["observation", "extraction", "validation", "corroboration", "attestation", "auditability", "anchoring", "monitoring"]
              },
              "surfaceClaimIds": {
                "type": "array",
                "items": { "type": "string" }
              },
              "summary": { "type": "string" },
              "externalTool": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tool", "format", "blocking", "artifactPath"],
                "properties": {
                  "tool": { "type": "string", "minLength": 1 },
                  "format": { "type": "string", "minLength": 1 },
                  "blocking": { "type": "boolean" },
                  "artifactPath": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^\\.veritas/"
                  }
                }
              }
            }
          },
          "minItems": 1
        },
        "requiredProofIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaultProofIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surfaceProofRoutes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nodeIds", "proofIds"],
            "properties": {
              "nodeIds": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "proofIds": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            }
          }
        },
        "proofSuiteManifests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uncoveredPathPolicy": {
          "type": "string",
          "enum": ["ignore", "warn", "fail"]
        },
        "reportTransport": { "type": "string" }
      },
      "anyOf": [
        { "required": ["proofs"] }
      ]
    }
  }
}
