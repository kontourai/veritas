{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-repo-map.schema.json",
  "title": "Veritas Repo Map",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "kind", "graph", "evidence"],
  "properties": {
    "name": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["repo-map"]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultFalsePositiveReview",
        "defaultPromotionCandidate",
        "defaultExceptionAllowed"
      ],
      "properties": {
        "defaultFalsePositiveReview": {
          "type": "string",
          "enum": ["unknown", "accepted", "rejected"]
        },
        "defaultPromotionCandidate": { "type": "boolean" },
        "defaultExceptionAllowed": { "type": "boolean" }
      }
    },
    "graph": {
      "allOf": [
        { "$ref": "./veritas-graph.schema.json" },
        {
          "type": "object",
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "owners": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "boundary": {
                    "type": "string",
                    "enum": ["strict", "advisory"]
                  },
                  "boundaryAllow": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aiInstructionFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "tool": { "type": "string" },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactDir", "reportTransport"],
      "properties": {
        "artifactDir": { "type": "string" },
        "evidenceChecks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "method"],
            "properties": {
              "id": { "type": "string" },
              "runner": { "enum": ["bash", "mcp"] },
              "command": { "type": "string" },
              "server": {
                "type": "object",
                "additionalProperties": false,
                "required": ["command", "args"],
                "properties": {
                  "command": { "type": "string", "minLength": 1 },
                  "args": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "env": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  }
                }
              },
              "tool": { "type": "string", "minLength": 1 },
              "input": { "type": "object" },
              "method": {
                "enum": ["observation", "extraction", "validation", "corroboration", "attestation", "auditability", "anchoring", "monitoring"]
              },
              "surfaceClaimIds": {
                "type": "array",
                "items": { "type": "string" }
              },
              "summary": { "type": "string" },
              "externalTool": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tool", "format", "blocking", "artifactPath"],
                "properties": {
                  "tool": { "type": "string", "minLength": 1 },
                  "format": { "type": "string", "minLength": 1 },
                  "blocking": { "type": "boolean" },
                  "artifactPath": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^\\.veritas/"
                  }
                }
              }
            }
          },
          "minItems": 1
        },
        "requiredEvidenceCheckIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaultEvidenceCheckIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidenceCheckRoutes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nodeIds", "evidenceCheckIds"],
            "properties": {
              "nodeIds": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "evidenceCheckIds": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            }
          }
        },
        "evidenceInventoryManifests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uncoveredPathPolicy": {
          "type": "string",
          "enum": ["ignore", "warn", "fail"]
        },
        "reportTransport": { "type": "string" }
      },
      "anyOf": [
        { "required": ["evidenceChecks"] }
      ]
    }
  }
}
