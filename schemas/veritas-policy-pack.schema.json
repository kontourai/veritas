{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-policy-pack.schema.json",
  "title": "Veritas Policy Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "rules"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "classification", "stage", "message"],
        "properties": {
          "id": { "type": "string" },
          "classification": {
            "type": "string",
            "enum": [
              "hard-invariant",
              "promotable-policy",
              "advisory-pattern",
              "brittle-implementation-check"
            ]
          },
          "stage": {
            "type": "string",
            "enum": ["recommend", "warn", "block"]
          },
          "message": { "type": "string" },
          "owner": { "type": ["string", "null"] },
          "rollback_switch": { "type": ["string", "null"] },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "artifacts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "governance-block": {
                "type": "array",
                "items": { "type": "string" }
              },
              "if-changed": { "type": "string" },
              "then-require": { "type": "string" },
              "files": {
                "type": "array",
                "items": { "type": "string" }
              },
              "workflow": { "type": "string" },
              "pattern": { "type": "string" }
            },
            "anyOf": [
              { "required": ["artifacts"] },
              { "required": ["governance-block"] },
              { "required": ["if-changed", "then-require"] },
              { "required": ["files"] },
              { "required": ["workflow"] },
              { "required": ["pattern"] }
            ]
          }
        }
      }
    }
  }
}
