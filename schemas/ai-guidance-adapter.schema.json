{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-guidance-framework.dev/schemas/ai-guidance-adapter.schema.json",
  "title": "AI Guidance Adapter",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "kind", "graph", "evidence"],
  "properties": {
    "name": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["repo-adapter"]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultFalsePositiveReview",
        "defaultPromotionCandidate",
        "defaultOverrideOrBypass"
      ],
      "properties": {
        "defaultFalsePositiveReview": {
          "type": "string",
          "enum": ["unknown", "accepted", "rejected"]
        },
        "defaultPromotionCandidate": { "type": "boolean" },
        "defaultOverrideOrBypass": { "type": "boolean" }
      }
    },
    "graph": { "$ref": "./ai-guidance-graph.schema.json" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactDir", "reportTransport"],
      "properties": {
        "artifactDir": { "type": "string" },
        "requiredProofLanes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaultProofLanes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surfaceProofLanes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nodeIds", "proofLanes"],
            "properties": {
              "nodeIds": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "proofLanes": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            }
          }
        },
        "uncoveredPathPolicy": {
          "type": "string",
          "enum": ["ignore", "warn", "fail"]
        },
        "reportTransport": { "type": "string" }
      },
      "anyOf": [
        { "required": ["requiredProofLanes"] },
        { "required": ["defaultProofLanes"] },
        { "required": ["surfaceProofLanes"] }
      ]
    }
  }
}
