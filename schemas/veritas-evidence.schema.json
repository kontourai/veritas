{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-evidence.schema.json",
  "title": "Veritas Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "framework_version",
    "run_id",
    "timestamp",
    "source_ref",
    "source_kind",
    "source_scope",
    "resolved_phase",
    "resolved_workstream",
    "matched_artifacts",
    "affected_nodes",
    "affected_lanes",
    "selected_proof_commands",
    "proof_resolution_source",
    "uncovered_path_result",
    "baseline_ci_fast_passed",
    "recommendations",
    "false_positive_review",
    "promotion_candidate",
    "override_or_bypass",
    "files",
    "unresolved_files",
    "promotion_allowed",
    "framework",
    "adapter",
    "policy_pack",
    "policy_results"
  ],
  "properties": {
    "framework_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_ref": { "type": "string" },
    "source_kind": {
      "type": "string",
      "enum": ["explicit-files", "branch-diff", "working-tree"]
    },
    "source_scope": { "$ref": "#/$defs/stringArray" },
    "resolved_phase": { "type": "string" },
    "resolved_workstream": { "type": "string" },
    "matched_artifacts": { "$ref": "#/$defs/stringArray" },
    "affected_nodes": { "$ref": "#/$defs/stringArray" },
    "affected_lanes": { "$ref": "#/$defs/stringArray" },
    "selected_proof_commands": { "$ref": "#/$defs/stringArray" },
    "proof_resolution_source": { "type": "string" },
    "uncovered_path_result": {
      "type": "string",
      "enum": ["clear", "ignore", "warn", "fail"]
    },
    "baseline_ci_fast_passed": { "type": ["boolean", "null"] },
    "recommendations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "false_positive_review": { "$ref": "#/$defs/reviewState" },
    "promotion_candidate": { "type": "boolean" },
    "override_or_bypass": { "type": "boolean" },
    "owner": { "type": ["string", "null"] },
    "files": { "$ref": "#/$defs/stringArray" },
    "unresolved_files": { "$ref": "#/$defs/stringArray" },
    "promotion_allowed": { "type": "boolean" },
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "resolver_precedence", "policy_defaults"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "resolver_precedence": { "$ref": "#/$defs/stringArray" },
        "policy_defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "false_positive_review",
            "promotion_candidate",
            "override_or_bypass"
          ],
          "properties": {
            "false_positive_review": { "$ref": "#/$defs/reviewState" },
            "promotion_candidate": { "type": "boolean" },
            "override_or_bypass": { "type": "boolean" }
          }
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "report_transport",
        "default_resolution",
        "non_sliceable_invariants",
        "required_proof_lanes",
        "default_proof_lanes",
        "surface_proof_lanes",
        "uncovered_path_policy"
      ],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "report_transport": { "type": "string" },
        "default_resolution": { "$ref": "#/$defs/resolution" },
        "non_sliceable_invariants": { "$ref": "#/$defs/stringArray" },
        "required_proof_lanes": { "$ref": "#/$defs/stringArray" },
        "default_proof_lanes": { "$ref": "#/$defs/stringArray" },
        "surface_proof_lanes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node_ids", "proof_lanes"],
            "properties": {
              "node_ids": { "$ref": "#/$defs/stringArray" },
              "proof_lanes": { "$ref": "#/$defs/stringArray" }
            }
          }
        },
        "uncovered_path_policy": {
          "type": "string",
          "enum": ["ignore", "warn", "fail"]
        }
      }
    },
    "policy_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "rule_count"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "rule_count": { "type": "integer", "minimum": 0 }
      }
    },
    "policy_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/policyResult" }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reviewState": {
      "type": "string",
      "enum": ["unknown", "accepted", "rejected"]
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "workstream", "matchedArtifacts"],
      "properties": {
        "phase": { "type": "string" },
        "workstream": { "type": "string" },
        "matchedArtifacts": { "$ref": "#/$defs/stringArray" }
      }
    },
    "policyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "classification",
        "stage",
        "message",
        "owner",
        "rollback_switch",
        "implemented",
        "passed",
        "summary",
        "findings"
      ],
      "properties": {
        "rule_id": { "type": "string" },
        "classification": { "type": "string" },
        "stage": { "type": "string" },
        "message": { "type": "string" },
        "owner": { "type": ["string", "null"] },
        "rollback_switch": { "type": ["string", "null"] },
        "implemented": { "type": "boolean" },
        "passed": { "type": ["boolean", "null"] },
        "summary": { "type": "string" },
        "findings": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
