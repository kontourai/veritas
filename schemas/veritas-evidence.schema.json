{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-evidence.schema.json",
  "title": "Veritas Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "framework_version",
    "run_id",
    "timestamp",
    "source_ref",
    "source_kind",
    "source_scope",
    "resolved_phase",
    "resolved_workstream",
    "matched_artifacts",
    "affected_nodes",
    "affected_lanes",
    "selected_proof_commands",
    "selected_proof_lanes",
    "proof_resolution_source",
    "uncovered_path_result",
    "baseline_ci_fast_passed",
    "recommendations",
    "false_positive_review",
    "promotion_candidate",
    "override_or_bypass",
    "files",
    "unresolved_files",
    "promotion_allowed",
    "framework",
    "adapter",
    "policy_pack",
    "policy_results"
  ],
  "properties": {
    "framework_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source_ref": { "type": "string" },
    "source_kind": {
      "type": "string",
      "enum": ["explicit-files", "branch-diff", "working-tree"]
    },
    "source_scope": { "$ref": "#/$defs/stringArray" },
    "resolved_phase": { "type": "string" },
    "resolved_workstream": { "type": "string" },
    "matched_artifacts": { "$ref": "#/$defs/stringArray" },
    "affected_nodes": { "$ref": "#/$defs/stringArray" },
    "affected_lanes": { "$ref": "#/$defs/stringArray" },
    "selected_proof_commands": { "$ref": "#/$defs/stringArray" },
    "selected_proof_lanes": {
      "type": "array",
      "items": { "$ref": "#/$defs/proofLane" }
    },
    "proof_resolution_source": { "type": "string" },
    "proof_family_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/proofFamilyResult" }
    },
    "verification_budget": { "$ref": "#/$defs/verificationBudget" },
    "uncovered_path_result": {
      "type": "string",
      "enum": ["clear", "ignore", "warn", "fail"]
    },
    "baseline_ci_fast_passed": { "type": ["boolean", "null"] },
    "recommendations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "false_positive_review": { "$ref": "#/$defs/reviewState" },
    "promotion_candidate": { "type": "boolean" },
    "override_or_bypass": { "type": "boolean" },
    "owner": { "type": ["string", "null"] },
    "files": { "$ref": "#/$defs/stringArray" },
    "unresolved_files": { "$ref": "#/$defs/stringArray" },
    "promotion_allowed": { "type": "boolean" },
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "resolver_precedence", "policy_defaults"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "resolver_precedence": { "$ref": "#/$defs/stringArray" },
        "policy_defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "false_positive_review",
            "promotion_candidate",
            "override_or_bypass"
          ],
          "properties": {
            "false_positive_review": { "$ref": "#/$defs/reviewState" },
            "promotion_candidate": { "type": "boolean" },
            "override_or_bypass": { "type": "boolean" }
          }
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "report_transport",
        "default_resolution",
        "non_sliceable_invariants",
        "proof_lanes",
        "required_proof_lane_ids",
        "default_proof_lane_ids",
        "surface_proof_lanes",
        "uncovered_path_policy"
      ],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "report_transport": { "type": "string" },
        "default_resolution": { "$ref": "#/$defs/resolution" },
        "non_sliceable_invariants": { "$ref": "#/$defs/stringArray" },
        "proof_lanes": {
          "type": "array",
          "items": { "$ref": "#/$defs/proofLane" }
        },
        "required_proof_lane_ids": { "$ref": "#/$defs/stringArray" },
        "default_proof_lane_ids": { "$ref": "#/$defs/stringArray" },
        "surface_proof_lanes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node_ids", "proof_lane_ids"],
            "properties": {
              "node_ids": { "$ref": "#/$defs/stringArray" },
              "proof_lane_ids": { "$ref": "#/$defs/stringArray" }
            }
          }
        },
        "uncovered_path_policy": {
          "type": "string",
          "enum": ["ignore", "warn", "fail"]
        }
      }
    },
    "policy_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "rule_count"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "rule_count": { "type": "integer", "minimum": 0 }
      }
    },
    "policy_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/policyResult" }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reviewState": {
      "type": "string",
      "enum": ["unknown", "accepted", "rejected"]
    },
    "proofLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command", "method", "surface_claim_ids", "summary"],
      "properties": {
        "id": { "type": "string" },
        "command": { "type": "string" },
        "method": {
          "enum": ["observation", "extraction", "validation", "corroboration", "attestation", "auditability", "anchoring", "monitoring"]
        },
        "surface_claim_ids": { "$ref": "#/$defs/stringArray" },
        "summary": { "type": "string" }
      }
    },
    "proofFamilyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "lane_id",
        "source_proof_lane_id",
        "manifest_path",
        "destination",
        "owner",
        "disposition",
        "blocking_status",
        "verification_weight",
        "selected",
        "recent_catch_evidence",
        "regression_severity",
        "false_positive_risk",
        "replacement_test_available",
        "review_trigger",
        "last_reviewed",
        "evidence_basis",
        "freshness_status",
        "rationale"
      ],
      "properties": {
        "id": { "type": "string" },
        "lane_id": { "type": "string" },
        "source_proof_lane_id": { "type": ["string", "null"] },
        "manifest_path": { "type": "string" },
        "destination": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"] },
        "disposition": {
          "type": "string",
          "enum": ["required", "candidate", "advisory", "move-to-test", "retire", "upstream-abstraction"]
        },
        "blocking_status": { "type": "string" },
        "verification_weight": {
          "type": "string",
          "enum": ["blocking", "advisory", "informational"]
        },
        "selected": { "type": "boolean" },
        "recent_catch_evidence": { "type": "string" },
        "regression_severity": { "type": "string" },
        "false_positive_risk": { "type": "string" },
        "replacement_test_available": { "type": ["string", "null"] },
        "review_trigger": { "type": ["string", "null"] },
        "last_reviewed": { "type": ["string", "null"] },
        "evidence_basis": { "type": "string" },
        "freshness_status": {
          "type": "string",
          "enum": ["current", "review-needed", "stale", "retiring"]
        },
        "rationale": { "type": "string" }
      }
    },
    "verificationBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_lane_count",
        "selected_proof_lane_count",
        "proof_family_count",
        "required_family_count",
        "candidate_family_count",
        "advisory_family_count",
        "move_to_test_family_count",
        "retire_family_count",
        "upstream_candidate_count",
        "unknown_catch_evidence_family_ids",
        "missing_review_trigger_family_ids",
        "stale_family_ids",
        "stale_or_unknown_family_ids",
        "recommendation"
      ],
      "properties": {
        "proof_lane_count": { "type": "integer", "minimum": 0 },
        "selected_proof_lane_count": { "type": "integer", "minimum": 0 },
        "proof_family_count": { "type": "integer", "minimum": 0 },
        "required_family_count": { "type": "integer", "minimum": 0 },
        "candidate_family_count": { "type": "integer", "minimum": 0 },
        "advisory_family_count": { "type": "integer", "minimum": 0 },
        "move_to_test_family_count": { "type": "integer", "minimum": 0 },
        "retire_family_count": { "type": "integer", "minimum": 0 },
        "upstream_candidate_count": { "type": "integer", "minimum": 0 },
        "unknown_catch_evidence_family_ids": { "$ref": "#/$defs/stringArray" },
        "missing_review_trigger_family_ids": { "$ref": "#/$defs/stringArray" },
        "stale_family_ids": { "$ref": "#/$defs/stringArray" },
        "stale_or_unknown_family_ids": { "$ref": "#/$defs/stringArray" },
        "recommendation": { "type": "string" }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "workstream", "matchedArtifacts"],
      "properties": {
        "phase": { "type": "string" },
        "workstream": { "type": "string" },
        "matchedArtifacts": { "$ref": "#/$defs/stringArray" }
      }
    },
    "policyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "classification",
        "stage",
        "message",
        "owner",
        "rollback_switch",
        "implemented",
        "passed",
        "summary",
        "findings"
      ],
      "properties": {
        "rule_id": { "type": "string" },
        "classification": { "type": "string" },
        "stage": { "type": "string" },
        "message": { "type": "string" },
        "owner": { "type": ["string", "null"] },
        "rollback_switch": { "type": ["string", "null"] },
        "implemented": { "type": "boolean" },
        "passed": { "type": ["boolean", "null"] },
        "summary": { "type": "string" },
        "findings": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
