{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/veritas-attestation.schema.json",
  "title": "Veritas Attestation",
  "type": "object",
  "required": [
    "id",
    "kind",
    "actor",
    "attestedAt",
    "repoStandardsHash",
    "repoMapHash",
    "authoritySettingsHash",
    "priorAttestationId",
    "validUntilDays",
    "notes"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string" },
    "kind": { "enum": ["bootstrap", "policy-change", "recommendation-acceptance"] },
    "actor": {
      "type": "object",
      "required": ["id", "displayName", "identityEvidence"],
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "identityEvidence": {
          "type": "object",
          "required": ["gitEmail", "signingKeyFingerprint"],
          "properties": {
            "gitEmail": { "type": ["string", "null"] },
            "signingKeyFingerprint": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "attestedAt": { "type": "string", "format": "date-time" },
    "repoStandardsHash": { "type": "string" },
    "repoMapHash": { "type": "string" },
    "authoritySettingsHash": { "type": "string" },
    "priorAttestationId": { "type": ["string", "null"] },
    "validUntilDays": { "type": "integer", "minimum": 1 },
    "notes": { "type": "string" },
    "metadata": {
      "type": "object",
      "properties": {
        "approvalRef": { "type": ["string", "null"] },
        "approvalRefPolicy": {
          "type": "object",
          "properties": {
            "mode": { "type": "string" },
            "matchedPrefix": { "type": ["string", "null"] },
            "requiresResolution": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "approvalResolution": {
          "type": ["object", "null"],
          "properties": {
            "schemaVersion": { "type": "integer" },
            "status": {
              "type": "string",
              "enum": ["approved", "rejected", "unresolved", "expired", "out-of-scope", "error"]
            },
            "approved": { "type": "boolean" },
            "approvalRef": { "type": ["string", "null"] },
            "provider": { "type": ["string", "null"] },
            "authorityRef": { "type": ["string", "null"] },
            "approvedBy": { "type": ["string", "null"] },
            "approvedAt": { "type": ["string", "null"] },
            "expiresAt": { "type": ["string", "null"] },
            "scope": { "type": ["object", "null"] },
            "evidenceHash": { "type": ["string", "null"] },
            "resolvedAt": { "type": "string" },
            "failureReason": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
