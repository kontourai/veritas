{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-authority-settings.schema.json",
  "title": "Veritas Authority Settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "name",
    "defaults",
    "review_preferences",
    "promotion_preferences"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "new_rule_enforcement_level"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["observe", "assist", "gate"]
        },
        "new_rule_enforcement_level": {
          "description": "Default Enforcement Level (Observe/Guide/Require) seeded onto a newly promoted requirement.",
          "type": "string",
          "enum": ["Observe", "Guide", "Require"]
        }
      }
    },
    "review_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_signoff_required_for_stage_promotion",
        "reviewer_confidence_scale"
      ],
      "properties": {
        "human_signoff_required_for_stage_promotion": { "type": "boolean" },
        "reviewer_confidence_scale": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "major_rewrite_definition": { "type": "string" },
        "attestation_approval_ref_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["reference-only", "prefix", "resolved", "resolved-strict"]
            },
            "allowed_prefixes": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "promotion_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_checks_required_before_require"],
      "properties": {
        "evidence_checks_required_before_require": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings_block_in_ci": { "type": "boolean" },
        "require_consistent_feedback_before_promotion": { "type": "boolean" }
      }
    }
  }
}
