{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veritas.dev/schemas/veritas-graph.schema.json",
  "title": "Veritas Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "nodes", "resolverPrecedence"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "defaultResolution": {
      "$ref": "#/$defs/resolution"
    },
    "nonSliceableInvariants": {
      "$ref": "#/$defs/stringArray"
    },
    "resolverPrecedence": {
      "$ref": "#/$defs/stringArray"
    },
    "resolutionRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "match", "resolution"],
        "properties": {
          "id": { "type": "string" },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "required": ["patterns"],
            "properties": {
              "patterns": { "$ref": "#/$defs/stringArray" }
            }
          },
          "resolution": { "$ref": "#/$defs/resolution" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "label", "patterns"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "product-area",
              "shared-contract-area",
              "verification-area",
              "protected-area",
              "tooling-area",
              "delivery-area",
              "shared-package",
              "example-area"
            ]
          },
          "label": { "type": "string" },
          "patterns": { "$ref": "#/$defs/stringArray" },
          "owners": { "$ref": "#/$defs/stringArray" },
          "boundary": {
            "type": "string",
            "enum": ["strict", "advisory"]
          },
          "boundaryAllow": { "$ref": "#/$defs/stringArray" }
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "workstream", "matchedArtifacts"],
      "properties": {
        "phase": { "type": "string" },
        "workstream": { "type": "string" },
        "matchedArtifacts": { "$ref": "#/$defs/stringArray" }
      }
    }
  }
}
