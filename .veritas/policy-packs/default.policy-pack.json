{
  "version": 1,
  "name": "veritas-default",
  "description": "Conservative starter policy pack for a newly bootstrapped AI-guided repository.",
  "rules": [
    {
      "id": "required-veritas-operational-artifacts",
      "classification": "hard-invariant",
      "stage": "block",
      "message": "The tracked Veritas operational artifacts must stay present so agents and reviewers share the same baseline.",
      "owner": "repo-core",
      "rollback_switch": null,
      "match": {
        "artifacts": [
          ".veritas/GOVERNANCE.md",
          ".veritas/README.md",
          ".veritas/repo.adapter.json",
          ".veritas/policy-packs/default.policy-pack.json",
          ".veritas/team/default.team-profile.json"
        ]
      }
    },
    {
      "id": "required-veritas-cli-artifacts",
      "classification": "hard-invariant",
      "stage": "block",
      "message": "The shipped Veritas CLI entrypoints and package manifest must stay present.",
      "owner": "repo-core",
      "rollback_switch": null,
      "match": {
        "artifacts": [
          "package-lock.json",
          "package.json",
          "bin/veritas.mjs",
          "bin/veritas-report.mjs"
        ]
      }
    },
    {
      "id": "required-veritas-reference-artifacts",
      "classification": "hard-invariant",
      "stage": "block",
      "message": "The repo must keep the docs that explain the shipped Veritas surface.",
      "owner": "repo-core",
      "rollback_switch": null,
      "match": {
        "artifacts": [
          "README.md",
          "docs/README.md",
          "docs/reference/cli.md",
          "docs/reference/artifacts-and-schemas.md",
          "docs/reference/examples.md"
        ]
      }
    },
    {
      "id": "required-veritas-schema-artifacts",
      "classification": "hard-invariant",
      "stage": "block",
      "message": "The shipped Veritas schema set must stay present and reviewable.",
      "owner": "repo-core",
      "rollback_switch": null,
      "match": {
        "artifacts": [
          "schemas/veritas-adapter.schema.json",
          "schemas/veritas-eval-draft.schema.json",
          "schemas/veritas-eval-record.schema.json",
          "schemas/veritas-evidence.schema.json",
          "schemas/veritas-graph.schema.json",
          "schemas/veritas-policy-pack.schema.json",
          "schemas/veritas-team-profile.schema.json"
        ]
      }
    },
    {
      "id": "prefer-veritas-routed-delivery",
      "classification": "promotable-policy",
      "stage": "recommend",
      "message": "Prefer keeping the tracked Veritas proof and check-in integration surfaces present so changes flow through the documented operational path before review.",
      "owner": "repo-maintainers",
      "rollback_switch": "soften-veritas-route",
      "match": {
        "artifacts": [
          ".githooks/post-commit",
          ".veritas/hooks/agent-runtime.sh",
          ".veritas/runtime/codex-hooks.json",
          ".github/workflows/veritas-checkins.yml"
        ]
      }
    }
  ]
}
