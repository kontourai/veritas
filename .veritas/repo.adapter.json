{
  "name": "veritas",
  "kind": "repo-adapter",
  "policy": {
    "defaultFalsePositiveReview": "unknown",
    "defaultPromotionCandidate": false,
    "defaultOverrideOrBypass": false
  },
  "graph": {
    "version": 1,
    "defaultResolution": {
      "phase": "Phase 0 (Bootstrap)",
      "workstream": "Initial Project Setup",
      "matchedArtifacts": [
        "README.md"
      ]
    },
    "nonSliceableInvariants": [
      "baseline proof lane",
      "repo-local guidance",
      "tracked policy artifacts"
    ],
    "resolverPrecedence": [
      "explicit task or issue reference",
      "matching local artifact under .veritas/**",
      "active repo roadmap or README guidance",
      "multi-workstream fallback suppresses promotion"
    ],
    "resolutionRules": [
      {
        "id": "veritas-files",
        "match": {
          "patterns": [
            ".veritas/"
          ]
        },
        "resolution": {
          "phase": "Phase 0 (Bootstrap)",
          "workstream": "Initial Project Setup",
          "matchedArtifacts": [
            ".veritas/**"
          ]
        }
      }
    ],
    "nodes": [
      {
        "id": "governance.guidance",
        "kind": "governance-surface",
        "label": ".veritas/**",
        "governance-locked": true,
        "patterns": [
          ".veritas/"
        ],
        "owners": ["governance-team"],
        "boundary": "strict",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "governance.root-manifests",
        "kind": "governance-surface",
        "label": "root manifests",
        "patterns": [
          "package.json",
          "package-lock.json",
          "README.md",
          "CLAUDE.md",
          "CONTRIBUTING.md",
          ".gitignore",
          "AGENTS.md"
        ],
        "owners": ["repo-core"],
        "boundary": "strict",
        "crossSurfaceAllow": ["docs-team"]
      },
      {
        "id": "tooling.bin",
        "kind": "tooling-surface",
        "label": "bin/**",
        "patterns": [
          "bin/"
        ],
        "owners": ["cli-team"],
        "boundary": "strict",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "delivery.github",
        "kind": "delivery-surface",
        "label": ".github/**",
        "patterns": [
          ".github/"
        ],
        "owners": ["delivery-team"],
        "boundary": "strict",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "tooling.scripts",
        "kind": "tooling-surface",
        "label": "scripts/**",
        "patterns": [
          "scripts/"
        ],
        "owners": ["tooling-team"],
        "boundary": "advisory",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "governance.schemas",
        "kind": "governance-surface",
        "label": "schemas/**",
        "patterns": [
          "schemas/"
        ],
        "owners": ["schema-team"],
        "boundary": "strict",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "governance.adapters",
        "kind": "governance-surface",
        "label": "adapters/**",
        "patterns": [
          "adapters/"
        ],
        "owners": ["adapter-team"],
        "boundary": "strict",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "governance.policy-packs",
        "kind": "governance-surface",
        "label": "policy-packs/**",
        "patterns": [
          "policy-packs/"
        ],
        "owners": ["governance-team"],
        "boundary": "strict",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "examples.fixtures",
        "kind": "example-surface",
        "label": "examples/**",
        "patterns": [
          "examples/"
        ],
        "owners": ["shared"],
        "boundary": "advisory",
        "crossSurfaceAllow": []
      },
      {
        "id": "app.src",
        "kind": "product-surface",
        "label": "src/**",
        "patterns": [
          "src/"
        ],
        "owners": ["framework-team"],
        "boundary": "strict",
        "crossSurfaceAllow": ["repo-core", "cli-team"]
      },
      {
        "id": "docs.docs",
        "kind": "product-surface",
        "label": "docs/**",
        "patterns": [
          "docs/"
        ],
        "owners": ["docs-team"],
        "boundary": "advisory",
        "crossSurfaceAllow": ["repo-core"]
      },
      {
        "id": "verification.tests",
        "kind": "verification-surface",
        "label": "tests/**",
        "patterns": [
          "tests/"
        ],
        "owners": ["shared"],
        "boundary": "advisory",
        "crossSurfaceAllow": []
      }
    ]
  },
  "evidence": {
    "artifactDir": ".veritas/evidence",
    "reportTransport": "local-json",
    "uncoveredPathPolicy": "warn",
    "proofs": [
      {
        "id": "required-proof",
        "command": "npm run verify",
        "method": "validation",
        "summary": "Runs npm run verify."
      },
      {
        "id": "fallow-advisory",
        "command": "npm run veritas:fallow:advisory",
        "method": "auditability",
        "summary": "Runs Fallow as advisory codebase-intelligence evidence.",
        "externalTool": {
          "tool": "fallow",
          "format": "veritas-fallow-advisory-v1",
          "blocking": false,
          "artifactPath": ".veritas/external/fallow-audit.json"
        }
      }
    ],
    "requiredProofIds": [
      "required-proof"
    ],
    "defaultProofIds": [
      "required-proof",
      "fallow-advisory"
    ]
  },
  "activation": {
    "aiInstructionFiles": [
      {
        "path": "AGENTS.md",
        "tool": "codex",
        "required": true
      },
      {
        "path": "CLAUDE.md",
        "tool": "claude-code",
        "required": true
      },
      {
        "path": ".cursorrules",
        "tool": "cursor",
        "required": false
      },
      {
        "path": ".github/copilot-instructions.md",
        "tool": "github-copilot",
        "required": false
      }
    ]
  }
}
