{
  "name": "veritas",
  "kind": "repo-map",
  "policy": {
    "defaultFalsePositiveReview": "unknown",
    "defaultPromotionCandidate": false,
    "defaultExceptionAllowed": false
  },
  "graph": {
    "version": 1,
    "defaultResolution": {
      "phase": "Phase 0 (Bootstrap)",
      "workstream": "Initial Project Setup",
      "matchedArtifacts": [
        "README.md"
      ]
    },
    "nonSliceableInvariants": [
      "baseline evidenceCheck",
      "repo-local guidance",
      "tracked policy artifacts"
    ],
    "resolverPrecedence": [
      "explicit task or issue reference",
      "matching local artifact under .veritas/**",
      "active repo roadmap or README guidance",
      "multi-workstream fallback suppresses promotion"
    ],
    "resolutionRules": [
      {
        "id": "veritas-files",
        "match": {
          "patterns": [
            ".veritas/"
          ]
        },
        "resolution": {
          "phase": "Phase 0 (Bootstrap)",
          "workstream": "Initial Project Setup",
          "matchedArtifacts": [
            ".veritas/**"
          ]
        }
      }
    ],
    "nodes": [
      {
        "id": "governance.guidance",
        "kind": "protected-area",
        "label": ".veritas/**",
        "governance-locked": true,
        "patterns": [
          ".veritas/"
        ],
        "owners": [
          "governance-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "governance.root-manifests",
        "kind": "protected-area",
        "label": "root manifests",
        "patterns": [
          "package.json",
          "package-lock.json",
          "README.md",
          "CHANGELOG.md",
          "CONTEXT.md",
          "CLAUDE.md",
          "CODE_OF_CONDUCT.md",
          "CONTRIBUTING.md",
          "LICENSE",
          "SECURITY.md",
          ".cursorrules",
          ".editorconfig",
          ".gitignore",
          "AGENTS.md",
          "surface.config.json",
          "veritas.claims.json",
          "release-please-config.json",
          ".release-please-manifest.json"
        ],
        "owners": [
          "repo-core"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "docs-team"
        ]
      },
      {
        "id": "tooling.bin",
        "kind": "tooling-area",
        "label": "bin/**",
        "patterns": [
          "bin/"
        ],
        "owners": [
          "cli-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "delivery.github",
        "kind": "delivery-area",
        "label": ".github/**",
        "patterns": [
          ".github/"
        ],
        "owners": [
          "delivery-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "delivery.git-hooks",
        "kind": "delivery-area",
        "label": ".githooks/**",
        "patterns": [
          ".githooks/"
        ],
        "owners": [
          "delivery-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "tooling.scripts",
        "kind": "tooling-area",
        "label": "scripts/**",
        "patterns": [
          "scripts/"
        ],
        "owners": [
          "tooling-team"
        ],
        "boundary": "advisory",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "governance.schemas",
        "kind": "protected-area",
        "label": "schemas/**",
        "patterns": [
          "schemas/"
        ],
        "owners": [
          "schema-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "governance.repo-maps",
        "kind": "protected-area",
        "label": "repo-maps/**",
        "patterns": [
          "repo-maps/"
        ],
        "owners": [
          "repo-map-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "governance.repo-standards",
        "kind": "protected-area",
        "label": "repo-standards/**",
        "patterns": [
          "repo-standards/"
        ],
        "owners": [
          "governance-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "examples.example-data",
        "kind": "example-area",
        "label": "examples/**",
        "patterns": [
          "examples/"
        ],
        "owners": [
          "shared"
        ],
        "boundary": "advisory",
        "boundaryAllow": []
      },
      {
        "id": "app.src",
        "kind": "product-area",
        "label": "src/**",
        "patterns": [
          "src/"
        ],
        "owners": [
          "product-core-team"
        ],
        "boundary": "strict",
        "boundaryAllow": [
          "repo-core",
          "cli-team"
        ]
      },
      {
        "id": "docs.docs",
        "kind": "product-area",
        "label": "docs/**",
        "patterns": [
          "docs/"
        ],
        "owners": [
          "docs-team"
        ],
        "boundary": "advisory",
        "boundaryAllow": [
          "repo-core"
        ]
      },
      {
        "id": "verification.tests",
        "kind": "verification-area",
        "label": "tests/**",
        "patterns": [
          "tests/"
        ],
        "owners": [
          "shared"
        ],
        "boundary": "advisory",
        "boundaryAllow": []
      }
    ]
  },
  "evidence": {
    "artifactDir": ".kontourai/veritas/evidence",
    "reportTransport": "local-json",
    "uncoveredPathPolicy": "warn",
    "evidenceChecks": [
      {
        "id": "required-evidence-check",
        "command": "npm run verify",
        "method": "validation",
        "summary": "Runs npm run verify."
      },
      {
        "id": "fallow-advisory",
        "command": "npm run veritas:fallow:advisory",
        "method": "auditability",
        "summary": "Runs Fallow as advisory codebase-intelligence evidence.",
        "externalTool": {
          "tool": "fallow",
          "format": "veritas-fallow-advisory-v1",
          "blocking": false,
          "artifactPath": ".kontourai/veritas/external/fallow-audit.json"
        }
      },
      {
        "id": "vocabulary-consistency",
        "command": "npm run veritas:vocab:check",
        "method": "validation",
        "summary": "Checks first-contact Veritas docs for canonical product vocabulary."
      }
    ],
    "requiredEvidenceCheckIds": [
      "required-evidence-check"
    ],
    "defaultEvidenceCheckIds": [
      "required-evidence-check",
      "vocabulary-consistency",
      "fallow-advisory"
    ]
  },
  "activation": {
    "aiInstructionFiles": [
      {
        "path": "AGENTS.md",
        "tool": "codex",
        "required": true
      },
      {
        "path": "CLAUDE.md",
        "tool": "claude-code",
        "required": true
      },
      {
        "path": ".cursorrules",
        "tool": "cursor",
        "required": false
      },
      {
        "path": ".github/copilot-instructions.md",
        "tool": "github-copilot",
        "required": false
      }
    ]
  }
}
